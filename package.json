{
  "name": "@tgtone/auth-sdk",
  "version": "3.5.6",
  "description": "SDK de autenticación JWT + Bearer Token para el ecosistema TGT One",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react-hook.d.ts",
      "default": "./dist/react-hook.js"
    },
    "./interceptor": {
      "types": "./dist/interceptor.d.ts",
      "default": "./dist/interceptor.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "sso",
    "authentication",
    "tgtone",
    "jwt",
    "oauth",
    "identity"
  ],
  "author": "TGT Technology",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tgt-technology/tgtone-auth-sdk.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "MIGRATION_GUIDE.md",
    "docs"
  ],
  "dependencies": {
    "jwt-decode": "^4.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "^19.0.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "jest-location-mock": "^3.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ts-jest": "^29.4.9",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
